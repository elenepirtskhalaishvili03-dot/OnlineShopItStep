# Django
DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DEBUG=False
ALLOWED_HOSTS=.vercel.app
CSRF_TRUSTED_ORIGINS=https://*.vercel.app

# PostgreSQL (Supabase / external)
DB_ENGINE=django.db.backends.postgresql_psycopg2
DB_NAME=replace-with-db-name
DB_USER=replace-with-db-user
DB_PASSWORD=replace-with-db-password
DB_HOST=replace-with-db-host
DB_PORT=6543
DB_SSLMODE=require

# AWS S3 for media/static
USE_S3=True
AWS_STORAGE_BUCKET_NAME=replace-with-bucket-name
AWS_S3_REGION_NAME=us-west-1
AWS_ACCESS_KEY_ID=replace-with-access-key-id
AWS_SECRET_ACCESS_KEY=replace-with-secret-access-key
# Optional CloudFront/custom S3 domain
# AWS_S3_CUSTOM_DOMAIN=cdn.example.com

# Cookie behavior over HTTPS
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
JWT_COOKIE_SECURE=True
